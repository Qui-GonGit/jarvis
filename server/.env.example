PORT=3001
ANTHROPIC_API_KEY=

# Optional: enables a warm, cinematic JARVIS voice via ElevenLabs instead of
# the browser's built-in TTS. Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=
# Default voice: "Daniel", a deep calm voice with a hint of an English accent.
# Browse https://elevenlabs.io/voice-library for alternatives and paste the voice ID here.
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# Optional: override the default location used by the Weather panel
WEATHER_LAT=41.9028
WEATHER_LON=12.4964
WEATHER_CITY=Rome
WEATHER_COUNTRY=IT

# Optional: lets JARVIS check your important unread Gmail at the start of a
# conversation. Create OAuth credentials at https://console.cloud.google.com
# (Gmail API enabled, OAuth client type "Web application", redirect URI
# http://localhost:3001/api/email/oauth/callback).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/email/oauth/callback

# Comma-separated ETF tickers shown in the ETF dashboard widget, e.g.
# ETF_TICKERS=XBAE,XMME,XDWD
ETF_TICKERS=

# Optional: lets JARVIS check on Notion whether today's platform-engineering
# digest email has already been sent, instead of relying on browser
# localStorage. Create an internal integration at
# https://www.notion.so/my-integrations, then share the "Jarvis Digest Log"
# database with it (database "..." menu > Connections).
NOTION_API_KEY=
NOTION_DIGEST_DB_ID=
